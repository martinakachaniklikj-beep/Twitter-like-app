{
  "name": "twitter-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "yarn run build:backend && yarn run build:frontend",
    "build:backend": "yarn workspace backend run build",
    "build:frontend": "yarn workspace frontend run build",
    "start": "yarn workspace backend run start:prod",
    "start:backend": "yarn workspace backend run start:prod",
    "start:frontend": "yarn workspace frontend run start",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "test": "cd backend && npm run test",
    "check:prod": "npm run lint && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
